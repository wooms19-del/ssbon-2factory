rules_version = '2';

// 순수본 2공장 — Firebase Firestore 보안 룰
// 작성일: 2026-05-01
// 정책: 만료 없는 무제한 허용 (내부 시스템 가정)
//       기본 test mode와 동일한 동작이지만 만료일 없음

service cloud.firestore {
  match /databases/{database}/documents {

    // 모든 컬렉션: 누구나 read/write 가능
    // 만료일 없음 (영구 적용)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

